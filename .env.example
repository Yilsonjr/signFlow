# Supabase Configuration
# Obtén estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://<tu-project-ref>.supabase.co
SUPABASE_ANON_KEY=<tu-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# Lemon Squeezy Configuration
# Obtén estos valores en: https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=<tu-api-key>
# Obtén el Store ID en: https://app.lemonsqueezy.com → Settings → Store
LEMONSQUEEZY_STORE_ID=<tu-store-id>
# Obtén el Webhook Secret en: https://app.lemonsqueezy.com → Settings → Webhooks → tu webhook → Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=<tu-webhook-signing-secret>
LEMONSQUEEZY_ENVIRONMENT=test

# Application Configuration
APP_NAME=SignFlow
APP_URL=https://signflow-eight.vercel.app
